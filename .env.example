# Copy this file to .env and fill in the values.
# EXPO_PUBLIC_ variables are inlined at build time — restart the dev server
# after changing them. They are visible in the client bundle, so only use
# keys you can afford to expose.

# OpenRouter API key for the AI opponent (openai/gpt-oss-20b:free).
# Get one at https://openrouter.ai/keys
EXPO_PUBLIC_OPENROUTER_API_KEY=
