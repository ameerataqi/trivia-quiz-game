{
  "expo": {
    "name": "Trivia Blast",
    "slug": "trivia-blast",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "triviablast",
    "userInterfaceStyle": "light",
    "backgroundColor": "#12002E",
    "assetBundlePatterns": ["**/*"],
    "plugins": ["expo-status-bar"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.triviablast.app"
    },
    "android": {
      "package": "com.triviablast.app",
      "adaptiveIcon": {
        "backgroundColor": "#12002E"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "single"
    }
  }
}
